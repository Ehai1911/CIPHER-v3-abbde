{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 90
    },
    "api/nova.js": {
      "maxDuration": 15
    },
    "api/history.js": {
      "maxDuration": 10
    },
    "api/admin.js": {
      "maxDuration": 15
    },
    "api/parse-file.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/((?!api/|admin).*)", "destination": "/index.html" }
  ]
}
